<% layout("/layouts/boilerplate") %>

<section class="form-shell">
    <div class="col-lg-6 col-md-8">
        <div class="form-card">
        <span class="form-kicker">New Account</span>
        <h1 class="form-title">Create Your Account</h1>
        <p class="form-copy">Set up your profile to post listings, manage edits, and keep everything under one clean dashboard.</p>
        <form action="/signup" method="POST" class="needs-validation" novalidate>
            <div  class="mb-3 ">
                <label for="username" type="text" class="form-label">Username</label>
                <input  type ="text" id="username" name="username" class="form-control" required>
                <div class="valid-feedback">Username looks good.</div>
            
            </div>
            <div  class="mb-3 ">
                <label for="email" type="text" class="form-label">Email</label>
                <input  type ="text" id="email" name="email" class="form-control" required>
                
            
            </div>
            <div  class="mb-3 ">
                <label for="password" type="password" class="form-label">Password</label>
                <input  type ="password" id="password" name="password" class="form-control" required>
                
            
            </div>
            <button class="btn btn-warm submit-btn">Sign Up</button>
        </form>
        <p class="form-copy mt-4 mb-0">Already a member? <a href="/login" class="listing-link"><strong>Login instead</strong></a>.</p>
        </div>
    </div>
</section>
