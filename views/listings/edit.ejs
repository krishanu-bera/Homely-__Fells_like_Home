<% layout("/layouts/boilerplate") %>
<section class="form-shell">
  <div class="col-lg-8">
    <div class="form-card">
      <form method="POST" action="/listings/<%= listing._id %>" novalidate class="needs-validation" enctype="multipart/form-data">
        <input type="hidden" name="_method" value="PUT">
        <span class="form-kicker">Update Space</span>
        <h1 class="form-title">Edit Your Listing</h1>
        <p class="form-copy">Refresh the stay details, search metadata, and booking setup without losing the current quality of the page.</p>
        
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input id="title" name="listing[title]" value="<%= listing.title %>" type="text" class="form-control" required/>
          <div class="valid-feedback">Title looks good!</div>
          <div class="invalid-feedback">Need a title</div>
        </div>
        
        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea id="description" name="listing[description]" class="form-control" required><%= listing.description %></textarea>
          <div class="valid-feedback">Description is good!</div>
          <div class="invalid-feedback">Need a description</div>
        </div>

        <% if (gallery.length) { %>
          <div class="mb-3 gallery-preview-row">
            <% for (const image of gallery.slice(0, 4)) { %>
              <img class="gallery-preview-image" src="<%= image.url %>" alt="Current listing image">
            <% } %>
          </div>
        <% } %>
        
        <div class="listing-form-grid">
          <div class="mb-3">
            <label for="price" class="form-label">Price</label>
            <input id="price" name="listing[price]" value="<%= listing.price %>" type="number" min="0" class="form-control" required/>
            <div class="invalid-feedback">Please set a valid price.</div>
          </div>
          <div class="mb-3">
            <label for="maxGuests" class="form-label">Max Guests</label>
            <input id="maxGuests" name="listing[maxGuests]" value="<%= listing.maxGuests || 2 %>" type="number" min="1" class="form-control" required/>
          </div>
        </div>

        <div class="mb-3">
          <label for="category" class="form-label">Category</label>
          <select id="category" name="listing[category]" class="form-select">
            <% for (const category of categories) { %>
              <option value="<%= category %>" <%= listing.category === category ? "selected" : "" %>><%= category %></option>
            <% } %>
          </select>
        </div>
        
        <div class="mb-3">
          <label for="img">Replace Gallery Images</label>
          <input id="img" name="listing[images]" type="file" class="form-control" multiple />
          <div class="form-text">Leave empty to keep the current gallery.</div>
        </div>
        
        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input id="location" name="listing[location]" value="<%= listing.location %>" type="text" class="form-control" required />
          <div class="valid-feedback">Location set</div>
          <div class="invalid-feedback">Please enter the location.</div>
        </div>

        <div class="mb-3">
          <label for="country" class="form-label">Country</label>
          <input id="country" name="listing[country]" value="<%= listing.country %>" type="text" class="form-control" required />
          <div class="valid-feedback">Country set</div>
          <div class="invalid-feedback">Please enter the country.</div>
        </div>
        
        <button class="btn btn-warm submit-btn">Save Changes</button>
      </form>
      <p class="form-copy mt-4 mb-0">Fresh images, the right category, and an accurate guest limit make the search and booking experience feel intentional.</p>
    </div>
  </div>
</section>
