<% layout("/layouts/boilerplate") %>

<section class="form-shell">
    <div class="col-lg-6 col-md-8">
        <div class="form-card">
        <span class="form-kicker">Access</span>
        <h1 class="form-title">Login</h1>
        <p class="form-copy">Return to your listings, reviews, and saved browsing flow without the clutter.</p>
        <form action="/login" method="POST" class="needs-validation" novalidate>
            <div  class="mb-3 ">
                <label for="username" type="text" class="form-label">Username</label>
                <input  type ="text" id="username" name="username" class="form-control" required>
                
            
            </div>
           
            <div  class="mb-3 ">
                <label for="password" type="password" class="form-label">Password</label>
                <input  type ="password" id="password" name="password" class="form-control" required>
                
            
            </div>
            <button class="btn btn-warm submit-btn">Login</button>
        </form>
        <p class="form-copy mt-4 mb-0">New here? <a href="/signup" class="listing-link"><strong>Create an account</strong></a>.</p>
        </div>
    </div>
</section>
