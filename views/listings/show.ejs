<% layout("layouts/boilerplate") %>
<script>
  const mapToken ="<%= process.env.MAP_TOKEN %>";
 
</script>
<div class="row mt-3 mb-3">
  <div class="col-8 offset-3 ">
    <h2> <b><%= listing.title %> </b></h2>
  </div>
      
    <div class="card col-6 offset-3 show-card ls">
      <img src="<%= listing.image.url %>" class="card-img-top show-img mt-3" >
      <br>
       <p><b> Created by : </b><i><%= listing.owner.username %></i><br></p> 
       <p> <%= listing.description %> </p> 
        <p>&#8377;<%= listing.price ? listing.price.toLocaleString("en-In") : 'N/A' %> /night</p> 
        <p><%= listing.location %></p> 
        <p><%= listing.country %> </p> 
      
        
        
    </div>
      
  
  
    <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
        <div class=" btns mt-3">
          <a href="/listings/<%= listing._id %>/edit" class="  btn btn-outline-dark col-1 offset-3 mb-3">Edit </a>
          <br /><br />
          <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
            <button class="btn btn-outline-danger offset-5 mb-6">Delete </button>
          </form>
        </div>
    <%} %>
    
    <% if(currUser){ %>
   
      <div class="col-6 offset-3 mb-3">
    
        <h4>Leave some review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">
         
          <div class="mt-3 mb-3">
           <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-slot">
              
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>
          <div class="mt-3 mb-3">
            <label for="comment"class="form-label">comment</label>
            <textarea name="review[comment]" id="comment" class="form-control" required></textarea>
          </div >
          <button class="btn btn-outline-dark mt-3">Submit</button>
        </form>

      </div>
    <%}%>
   
    
    <div class="col-6 offset-3">
      <hr>
      <p><b> All Reviews :</b></p>
      
      
      <div class="row mb-3">
        <% for(review of listing.reviews) { %>
              <div class="card col-5 ms-3  mt-3" >
                <div class="card-body">
                  <h5 class="card-title"><b>creater:</b> @ <%= review.author.username %> </h5>

                   <p class="starability-result" data-rating="<%= review.rating %>">
                   
                    </p>
                   
                  <h5 class="card-title"><%= review.comment %></h5>
                  
                  
                  
                  
                </div>
                <form method="post" action="/listings/<%=listing._id %>/reviews/<%=review._id %>?_method=DELETE" >
                  <button class="btn btn-sm btn-outline-danger mb-3">delete</button>
                </form>
              </div>
        <%} %>
      </div>
      
    </div>
    <div class="col-6 offset-3 mb-3">
        <h2>Where you'll be</h2>
         <div id="map"></div>
      </div>
      

</div>
<script>
  mapboxgl.accessToken = mapToken;
    const map = new mapboxgl.Map({
        container: 'map', // container ID
        center: coordinates, // starting position [lng, lat]. Note that lat must be set between -90 and 90
        zoom: 9 // starting zoom
    });

     const marker1 = new mapboxgl.Marker()
        .setLngLat(coordinates)
        .addTo(map);


</script>
        
     
        
